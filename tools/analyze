#!/bin/bash
# 用法: ./analyze <日志文件>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/../config.json"

LOG_FILE="$1"
[ -z "$LOG_FILE" ] && { echo "用法: $0 <日志文件>"; exit 1; }
[ ! -f "$LOG_FILE" ] && { echo "错误: 找不到日志文件 $LOG_FILE"; exit 1; }

OLLAMA_HOST=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['ollama']['host'])")
NOW=$(date '+%Y-%m-%d %H:%M:%S')
LOG_LINES=$(wc -l < "$LOG_FILE")

if ! curl -sf --max-time 5 "http://${OLLAMA_HOST}/api/tags" > /dev/null 2>&1; then
    ANALYSIS="[LLM 不可用：${OLLAMA_HOST} 无响应]"
else
    ANALYSIS=$(python3 - <<PYEOF
import json, urllib.request, re

cfg = json.load(open("$CONFIG_FILE"))["ollama"]
log_tail = "".join(open("$LOG_FILE").readlines()[-150:])

prompt = f"""你是集群任务日志分析助手，请用中文简洁分析以下日志。

=== 日志末尾 ===
{log_tail}
=== 结束 ===

按以下格式输出，不要输出其他内容：
【任务状态】一句话说明
【关键信息】2~4 条重要信息
【异常警告】有则说明，无则填"无"
【建议操作】1 条建议，无则填"无"
"""

payload = {
    "model": cfg["model"],
    "messages": [{"role": "user", "content": prompt}],
    "stream": False,
    "options": {"temperature": 0.3, "num_predict": cfg["num_predict"]}
}

req = urllib.request.Request(
    f"http://{cfg['host']}/api/chat",
    data=json.dumps(payload).encode(),
    headers={"Content-Type": "application/json"},
    method="POST"
)
try:
    with urllib.request.urlopen(req, timeout=cfg["timeout"]) as resp:
        content = json.loads(resp.read())["message"]["content"]
        print(re.sub(r"<think>.*?</think>", "", content, flags=re.DOTALL).strip())
except Exception as e:
    print(f"[LLM 分析出错: {e}]")
PYEOF
)
fi

echo "$ANALYSIS"

bash "$SCRIPT_DIR/notify.sh" "📋 任务通知
━━━━━━━━━━━━━━━━
时间: ${NOW}
日志: ${LOG_FILE}（${LOG_LINES} 行）
━━━━━━━━━━━━━━━━
${ANALYSIS}
━━━━━━━━━━━━━━━━"